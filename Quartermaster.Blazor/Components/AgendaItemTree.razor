@using Quartermaster.Api.Meetings
@using Quartermaster.Blazor.Components.Inputs

@if (FlatItems.Count == 0) {
    <p class="text-secondary">Keine Tagesordnungspunkte vorhanden.</p>
}

@foreach (var entry in FlatItems) {
    var item = entry.Item;
    var isEditing = EditingItemId == item.Id;
    var isActive = ActiveItemId == item.Id;
    var rowClass = isActive ? "border-start border-3 border-primary" : "";

    <div class="d-flex align-items-start py-2 border-bottom @rowClass" style="padding-left: @(entry.Depth * 2)rem;">
        @if (Mode == AgendaTreeMode.MinuteTaking) {
            <div class="me-2" style="min-width: 28px;">
                @if (item.CompletedAt != null) {
                    <i class="bi bi-check-circle-fill text-success fs-5"></i>
                } else if (item.StartedAt != null) {
                    <i class="bi bi-play-circle-fill text-warning fs-5"></i>
                } else {
                    <i class="bi bi-circle text-secondary fs-5"></i>
                }
            </div>
        }

        <div class="me-2 text-secondary small" style="min-width: 3em;">@entry.Number</div>

        <div class="flex-grow-1">
            @if (isEditing) {
                <div class="input-group input-group-sm mb-1">
                    <input type="text" class="form-control"
                           @bind="EditingTitle" @bind:event="oninput"
                           placeholder="Titel des TOPs" />
                    <select class="form-select" style="max-width: 160px;" @bind="EditingItemType">
                        <option value="0">Diskussion</option>
                        <option value="1">Antrag</option>
                        <option value="2">Protokoll</option>
                        <option value="3">Pause</option>
                        <option value="4">Information</option>
                    </select>
                    <button class="btn btn-outline-primary" aria-label="Speichern" @onclick="() => SaveEdit(item)">
                        <i class="bi bi-check-lg"></i>
                    </button>
                    <button class="btn btn-outline-secondary" aria-label="Abbrechen" @onclick="CancelEdit">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                @if (EditingItemType == (int)AgendaItemType.Motion) {
                    <div class="mb-1">
                        <MotionPicker Value="@EditingMotionId" ValueChanged="OnEditingMotionChanged"
                                      InitialTitle="@item.MotionTitle" ChapterId="@ChapterId" />
                    </div>
                }
            } else {
                @if (Mode == AgendaTreeMode.MinuteTaking) {
                    <button class="btn btn-link text-start text-decoration-none p-0 fw-semibold"
                            @onclick="() => OnSelectActive.InvokeAsync(item.Id)">
                        @item.Title
                    </button>
                } else {
                    <span class="fw-semibold">@item.Title</span>
                }
                <span class="badge border @TypeBadgeClass(item.ItemType) ms-2">@TypeLabel(item.ItemType)</span>
                @if (item.ItemType == AgendaItemType.Motion && !string.IsNullOrEmpty(item.MotionTitle)) {
                    <span class="text-secondary small ms-2">→ @item.MotionTitle</span>
                }
            }
        </div>

        @if (Mode == AgendaTreeMode.Editor && !isEditing) {
            <div class="input-group input-group-sm ms-2" style="width: auto;">
                <button class="btn btn-outline-secondary" @onclick="() => OnAddChild.InvokeAsync(item.Id)"
                        title="Unterpunkt hinzufügen" aria-label="Unterpunkt hinzufügen">
                    <i class="bi bi-plus-lg"></i>
                </button>
                <button class="btn btn-outline-secondary" @onclick="() => OnReorder.InvokeAsync((item.Id, -1))"
                        title="Nach oben" aria-label="Nach oben">
                    <i class="bi bi-chevron-up"></i>
                </button>
                <button class="btn btn-outline-secondary" @onclick="() => OnReorder.InvokeAsync((item.Id, 1))"
                        title="Nach unten" aria-label="Nach unten">
                    <i class="bi bi-chevron-down"></i>
                </button>
                <button class="btn btn-outline-secondary" @onclick="() => StartEdit(item)"
                        title="Bearbeiten" aria-label="Bearbeiten">
                    <i class="bi bi-pencil"></i>
                </button>
                <button class="btn btn-outline-danger" @onclick="() => OnDelete.InvokeAsync(item.Id)"
                        title="Löschen" aria-label="Löschen">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        }
    </div>
}
