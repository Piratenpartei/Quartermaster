<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            @if (!string.IsNullOrEmpty(Icon)) {
                <i class="bi @Icon"></i>
            }
            @Title
            @if (TotalCount.HasValue) {
                <span class="badge bg-secondary ms-2">@TotalCount.Value</span>
            }
        </h5>
        <a href="@AllUrl" class="btn btn-sm btn-outline-secondary">Alle anzeigen</a>
    </div>
    @if (IsEmpty) {
        <div class="card-body text-secondary">@EmptyMessage</div>
    } else {
        @ChildContent
    }
</div>
