@using Quartermaster.Api.Motions

<div style="position: relative;" tabindex="-1" @onfocusout="ScheduleClose">
    <div class="input-group input-group-sm">
        <span class="input-group-text"><i class="bi bi-search"></i></span>
        <input type="text" class="form-control" placeholder="Antrag suchen..."
               value="@SearchText" @oninput="OnSearchInput" @onfocus="OnFocus" disabled="@Disabled" />
        @if (!string.IsNullOrEmpty(Value)) {
            <button class="btn btn-outline-secondary" type="button" aria-label="Auswahl löschen" @onclick="Clear">
                <i class="bi bi-x"></i>
            </button>
        }
    </div>
    @if (ShowDropdown) {
        <div class="list-group position-absolute w-100 shadow-sm" style="z-index: 1000; max-height: 250px; overflow-y: auto; top: 100%;">
            @if (Loading) {
                <div class="list-group-item py-1 small text-secondary">
                    <span class="spinner-border spinner-border-sm" role="status"></span> Lade...
                </div>
            } else if (FilteredMotions.Count == 0) {
                <div class="list-group-item py-1 small text-secondary">Keine offenen Anträge</div>
            } else {
                @foreach (var motion in FilteredMotions.Take(20)) {
                    <button type="button" class="list-group-item list-group-item-action py-1 small"
                            @onclick="() => SelectMotion(motion)">
                        @motion.Title
                        <span class="text-secondary ms-1">@motion.AuthorName</span>
                    </button>
                }
            }
            @if (!string.IsNullOrEmpty(ChapterId)) {
                <a class="list-group-item list-group-item-action py-1 small text-primary"
                   href="/Motions/Create?chapterId=@ChapterId" target="_blank">
                    <i class="bi bi-plus-circle"></i> Neuen Antrag anlegen
                </a>
            }
        </div>
    }
</div>
