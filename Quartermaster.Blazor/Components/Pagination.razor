@if (TotalPages > 1) {
    <div class="d-flex justify-content-center align-items-center gap-3">
        <nav>
            <ul class="pagination mb-0">
                <li class="page-item @(CurrentPage <= 1 ? "disabled" : "")">
                    <button class="page-link" aria-label="Vorherige Seite" @onclick="() => SetPage(CurrentPage - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                </li>
                @foreach (var pageNum in GetPageNumbers()) {
                    <li class="page-item @(pageNum == CurrentPage ? "active" : "")">
                        <button class="page-link" @onclick="() => SetPage(pageNum)">@pageNum</button>
                    </li>
                }
                <li class="page-item @(CurrentPage >= TotalPages ? "disabled" : "")">
                    <button class="page-link" aria-label="Nächste Seite" @onclick="() => SetPage(CurrentPage + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </li>
            </ul>
        </nav>

        <div class="d-flex align-items-center gap-2">
            <select class="form-select" style="width: auto;"
                    value="@CurrentPage" @onchange="OnJumpToPage">
                @for (var i = 1; i <= TotalPages; i++) {
                    <option value="@i">@i</option>
                }
            </select>
            <span class="text-secondary text-nowrap">/ @TotalPages</span>
        </div>
    </div>
}
