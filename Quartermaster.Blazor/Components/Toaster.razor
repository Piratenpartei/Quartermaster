<div class="toast-container">
    @foreach (var toast in ToastService.Toasts) {
        <div class="toast show qm-toast @(toast.Type != "" ? "border-" + toast.Type : "")"
             @onmouseenter=@(() => OnMouseEnter(toast))
             @onmouseleave=@(() => OnMouseLeave(toast))>
            <div class="d-flex">
                <div class="toast-body">
                    @toast.Content
                    @if (!string.IsNullOrEmpty(toast.Details)) {
                        <details class="mt-1">
                            <summary class="small text-secondary">Details</summary>
                            <pre class="small mb-0 mt-1" style="white-space: pre-wrap; max-height: 200px; overflow: auto;">@toast.Details</pre>
                        </details>
                    }
                </div>
                <button type="button" class="btn-close me-2 m-auto" @onclick=@(() => OnClose(toast))></button>
            </div>
            @if (toast.DurationMs.HasValue) {
                <div class="qm-toast-progress @(toast.Type != "" ? "bg-" + toast.Type : "bg-secondary")"
                     style="animation-duration: @(toast.DurationMs.Value)ms;"></div>
            }
        </div>
    }
</div>
