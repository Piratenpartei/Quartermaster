@using Quartermaster.Blazor.Components
@using Quartermaster.Api
@implements IDisposable
@inherits LayoutComponentBase

<nav class="navbar navbar-expand-lg bg-body-tertiary mb-3">
    <div class="container">
        <a class="navbar-brand" href="/">
            Quartermaster
        </a>
        <button class="navbar-toggler btn-hover-scale1" type="button" @onclick=ToggleMenu>
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse @(Collapsed ? "" : "show")">
            <ul class="navbar-nav me-auto mb-lg-0">
                <li class="nav-item">
                    <NavMenuButton HRef="/">Home</NavMenuButton>
                </li>
                <li class="nav-item">
                    <NavMenuDropdown>
                        <ButtonContent>Mitgliedsportal</ButtonContent>
                        <DropdownContent>
                            <li><a class="dropdown-item" href="/DueSelector/UserDataInput">Beitragseinstufung</a></li>
                            <li><a class="dropdown-item" href="/MembershipApplication/PersonalData">Mitgliedsantrag</a></li>
                            <li><a class="dropdown-item" href="/Motions/Create">Antrag einreichen</a></li>
                        </DropdownContent>
                    </NavMenuDropdown>
                </li>
                <RequirePermission AnyOfChapterPermissions="@PermissionIdentifier.BoardWorkPermissions">
                    <li class="nav-item">
                        <NavMenuDropdown>
                            <ButtonContent>Vorstandsarbeit</ButtonContent>
                            <DropdownContent>
                                <RequirePermission AnyChapterPermission="@PermissionIdentifier.ViewMotions">
                                    <li><a class="dropdown-item" href="/Administration/Motions">Anträge</a></li>
                                </RequirePermission>
                                <RequirePermission AnyChapterPermission="@PermissionIdentifier.ViewMeetings">
                                    <li><a class="dropdown-item" href="/Administration/Meetings">Sitzungen</a></li>
                                </RequirePermission>
                                <RequirePermission AnyChapterPermission="@PermissionIdentifier.ViewApplications">
                                    <li><a class="dropdown-item" href="/Administration/MembershipApplications">Mitgliedsanträge</a></li>
                                </RequirePermission>
                                <RequirePermission AnyChapterPermission="@PermissionIdentifier.ViewDueSelections">
                                    <li><a class="dropdown-item" href="/Administration/DueSelections">Beitragseinstufungen</a></li>
                                </RequirePermission>
                                <RequirePermission AnyChapterPermission="@PermissionIdentifier.ViewMembers">
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="/Administration/Members">Mitglieder</a></li>
                                </RequirePermission>
                                <RequirePermission AnyChapterPermission="@PermissionIdentifier.ViewEvents">
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="/Administration/Events">Events</a></li>
                                </RequirePermission>
                                <RequirePermission AnyChapterPermission="@PermissionIdentifier.ViewTemplates">
                                    <li><a class="dropdown-item" href="/Administration/EventTemplates">Event-Vorlagen</a></li>
                                </RequirePermission>
                            </DropdownContent>
                        </NavMenuDropdown>
                    </li>
                </RequirePermission>
                <RequirePermission RequireAuth="true">
                    <li class="nav-item">
                        <NavMenuDropdown>
                            <ButtonContent>Verwaltung</ButtonContent>
                            <DropdownContent>
                                <li><a class="dropdown-item" href="/Administration/AdministrativeDivisions">Gemeindedatenbank - Suche</a></li>
                                <li><a class="dropdown-item" href="/Administration/AdministrativeDivisionTree">Gemeindedatenbank - Struktur</a></li>
                            </DropdownContent>
                        </NavMenuDropdown>
                    </li>
                </RequirePermission>
                <RequirePermission AnyOfPermissions="@PermissionIdentifier.SystemPermissions">
                    <li class="nav-item">
                        <NavMenuDropdown>
                            <ButtonContent>System</ButtonContent>
                            <DropdownContent>
                                <RequirePermission GlobalPermission="@PermissionIdentifier.ViewOptions">
                                    <li><a class="dropdown-item" href="/Administration/Options">Einstellungen</a></li>
                                </RequirePermission>
                                <RequirePermission GlobalPermission="@PermissionIdentifier.ViewUsers">
                                    <li><a class="dropdown-item" href="/Administration/Users">Benutzer</a></li>
                                    <li><a class="dropdown-item" href="/Administration/LoginLockouts">Gesperrte Logins</a></li>
                                </RequirePermission>
                                <RequirePermission GlobalPermission="@PermissionIdentifier.ManageRoles">
                                    <li><a class="dropdown-item" href="/Administration/Roles">Rollen</a></li>
                                </RequirePermission>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/Administration/Chapters">Gliederungen - Liste</a></li>
                                <li><a class="dropdown-item" href="/Administration/ChapterTree">Gliederungen - Struktur</a></li>
                                <RequirePermission AnyChapterPermission="@PermissionIdentifier.ViewOfficers">
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="/Administration/ChapterOfficers">Vorstandsmitglieder</a></li>
                                </RequirePermission>
                                <RequirePermission GlobalPermission="@PermissionIdentifier.ViewAllMembers">
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="/Administration/Members">Mitglieder</a></li>
                                    <li><a class="dropdown-item" href="/Administration/Members/Import">Mitgliederimport</a></li>
                                    <li><a class="dropdown-item" href="/Administration/ImportStatus">Importstatus</a></li>
                                </RequirePermission>
                            </DropdownContent>
                        </NavMenuDropdown>
                    </li>
                </RequirePermission>
            </ul>
            <div class="d-flex align-items-center gap-2">
                @if (AuthService.IsAuthenticated) {
                    <a href="/Settings" class="text-body-secondary text-decoration-none me-1 btn-hover-scale1">
                        <i class="bi bi-person-fill"></i> @AuthService.CurrentUser?.DisplayName
                    </a>
                    <button class="btn btn-outline-secondary btn-sm btn-hover-scale1" @onclick=HandleLogout>
                        Abmelden
                    </button>
                } else {
                    <a href="/Login" class="btn btn-outline-primary btn-sm btn-hover-scale1">
                        Anmelden
                    </a>
                }
                <button class="btn btn-hover-color-body-bg btn-hover-scale1" @onclick=ToggleDarkMode>
                    @if (AppState.SelectedTheme == Theme.Dark) {
                        <i class="bi bi-brightness-high-fill"></i>
                    } else {
                        <i class="bi bi-moon-fill"></i>
                    }
                </button>
            </div>
        </div>
    </div>
</nav>

<div class="container mb-3">
    @Body
</div>

<div class="d-flex justify-content-end align-items-end"
     style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; padding: 0 1.5rem 1rem 0; pointer-events: none;">
    <Toaster />
</div>