<div class="container mb-3">
    @Body
</div>

<div class="d-flex justify-content-end align-items-end"
     style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; padding: 0 1.5rem 1rem 0; pointer-events: none;">
    <Toaster />
</div>