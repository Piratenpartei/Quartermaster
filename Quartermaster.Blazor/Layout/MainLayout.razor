                            <li><a class="dropdown-item" href="/Motions/Create">Antrag einreichen</a></li>
                        </DropdownContent>
                    </NavMenuDropdown>
                </li>
                <li class="nav-item">
                    <NavMenuDropdown>
                        <ButtonContent>Vorstandsarbeit</ButtonContent>
                        <DropdownContent>
                            <li><a class="dropdown-item" href="/Administration/Motions">Anträge</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/Administration/MembershipApplications">Mitgliedsanträge</a></li>
