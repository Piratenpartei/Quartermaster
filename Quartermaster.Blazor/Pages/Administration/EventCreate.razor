@page "/Administration/Events/Create"
@using Quartermaster.Api.Events

<PageBackLink Href="/Administration/Events" />

<h3 class="mb-3">Neues Event erstellen</h3>

<div class="card">
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label">Gliederung</label>
            <ChapterPicker @bind-Value="ChapterId" />
        </div>
        <div class="mb-3">
            <label class="form-label">Name</label>
            <input type="text" class="form-control" @bind="InternalName" placeholder="Interner Name des Events" />
        </div>
        <button class="btn btn-primary" @onclick="Submit" disabled="@Submitting">
            @if (Submitting) {
                <span class="spinner-border spinner-border-sm" role="status"></span>
                <span> Wird erstellt...</span>
            } else {
                <i class="bi bi-plus-circle"></i>
                <span> Event erstellen</span>
            }
        </button>
    </div>
</div>
