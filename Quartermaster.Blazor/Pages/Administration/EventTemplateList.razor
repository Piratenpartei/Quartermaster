@page "/Administration/EventTemplates"
@using Quartermaster.Api.Events

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Event-Vorlagen</h3>
    <a href="/Administration/Events" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Zurück zu Events
    </a>
</div>

@if (Loading) {
    <div class="d-flex justify-content-center my-4">
        <div class="spinner-border" role="status"></div>
    </div>
} else if (Templates != null && Templates.Count > 0) {
    <div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Variablen</th>
                <th>Checkliste</th>
                <th>Erstellt</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var template in Templates) {
                <tr>
                    <td>@template.Name</td>
                    <td>@template.VariableCount</td>
                    <td>@template.ChecklistItemCount</td>
                    <td>@template.CreatedAt.ToString("dd.MM.yyyy")</td>
                    <td class="text-end">
                        <a href="/Administration/Events/CreateFromTemplate/@template.Id"
                           class="btn btn-sm btn-primary me-1">
                            <i class="bi bi-plus-circle"></i> Aus Vorlage erstellen
                        </a>
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => Delete(template.Id)"
                                disabled="@Deleting">
                            <i class="bi bi-trash"></i> Löschen
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>
} else {
    <div class="alert alert-info">
        Keine Vorlagen vorhanden. Erstellen Sie eine Vorlage aus einem bestehenden Event.
    </div>
}

<ConfirmDialog @ref="ConfirmDialog" />
