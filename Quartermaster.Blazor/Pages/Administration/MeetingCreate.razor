@page "/Administration/Meetings/Create"
@using Quartermaster.Api.Meetings

<PageBackLink Href="/Administration/Meetings" />

<h3 class="mb-3">Neue Sitzung erstellen</h3>

<div class="card">
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label">Gliederung</label>
            <ChapterPicker @bind-Value="ChapterId" />
        </div>
        <div class="mb-3">
            <label for="title" class="form-label">Titel</label>
            <input type="text" class="form-control" id="title" @bind="Title" maxlength="200" placeholder="Titel der Sitzung" />
        </div>
        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label for="meetingDate" class="form-label">Datum &amp; Uhrzeit</label>
                <input type="datetime-local" class="form-control" id="meetingDate" @bind="MeetingDate" />
            </div>
            <div class="col-md-6">
                <label for="location" class="form-label">Ort</label>
                <input type="text" class="form-control" id="location" @bind="Location" maxlength="500" placeholder="Ort (optional)" />
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label d-block">Sichtbarkeit</label>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" id="visPublic" name="visibility"
                       checked="@(Visibility == MeetingVisibility.Public)"
                       @onchange="() => Visibility = MeetingVisibility.Public" />
                <label class="form-check-label" for="visPublic">Öffentlich</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" id="visPrivate" name="visibility"
                       checked="@(Visibility == MeetingVisibility.Private)"
                       @onchange="() => Visibility = MeetingVisibility.Private" />
                <label class="form-check-label" for="visPrivate">Privat</label>
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label">Beschreibung (Markdown)</label>
            <MarkdownEditorWithPreview @bind-Value="Description" Rows="6" />
        </div>
        <button class="btn btn-primary" @onclick="Submit" disabled="@Submitting">
            @if (Submitting) {
                <span class="spinner-border spinner-border-sm" role="status"></span>
                <span> Wird erstellt...</span>
            } else {
                <i class="bi bi-plus-circle"></i>
                <span> Erstellen und Agenda bearbeiten</span>
            }
        </button>
    </div>
</div>
