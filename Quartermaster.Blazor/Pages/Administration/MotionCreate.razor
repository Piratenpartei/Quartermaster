@page "/Administration/Motions/Create"
@using Quartermaster.Api.Motions
@using Quartermaster.Api.Rendering

<PageBackLink Href="/Administration/Motions" />

<h3 class="mb-3">Neuen Antrag erstellen</h3>

<div class="card">
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label">Gliederung</label>
            <ChapterPicker @bind-Value="ChapterId" />
        </div>
        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label">Antragsteller (Name)</label>
                <input type="text" class="form-control" @bind="AuthorName" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Antragsteller (E-Mail)</label>
                <input type="email" class="form-control" @bind="AuthorEMail" />
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label">Titel</label>
            <input type="text" class="form-control" @bind="Title" />
        </div>
        <div class="mb-3">
            <label class="form-label">Antragstext (Markdown)</label>
            <MarkdownEditor @bind-Value="Text" Rows="8" Profile="SanitizationProfile.Strict" />
        </div>
        <button class="btn btn-primary" @onclick="Submit" disabled="@Submitting">
            @if (Submitting) {
                <span class="spinner-border spinner-border-sm" role="status"></span>
                <span> Wird erstellt...</span>
            } else {
                <i class="bi bi-plus-circle"></i>
                <span> Antrag erstellen</span>
            }
        </button>
    </div>
</div>
