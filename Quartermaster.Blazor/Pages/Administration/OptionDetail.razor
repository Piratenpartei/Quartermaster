@page "/Administration/Options/{Id:guid}"
@using Quartermaster.Api.Options
@using Quartermaster.Api.Chapters

<div class="mb-3">
    <a href="/Administration/Options" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Zurück zur Übersicht
    </a>
</div>

@if (Loading) {
    <div class="d-flex justify-content-center my-4">
        <div class="spinner-border" role="status"></div>
    </div>
} else if (Option == null) {
    <div class="alert alert-danger">Einstellung nicht gefunden.</div>
} else {
    <h3 class="mb-3">@Option.FriendlyName</h3>

    <div class="row">
        <div class="@(Option.DataType == 2 && Schemas != null && Schemas.Count > 0 ? "col-lg-8" : "col-12")">
            <DirtyForm @ref="_globalForm">
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h5 class="mb-1">Globaler Wert</h5>
                                <code class="text-secondary small">@Option.Identifier</code>
                                <span class="badge border ms-2 @DataTypeBadge(Option.DataType)">@DataTypeLabel(Option.DataType)</span>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(Option.Description)) {
                            <p class="text-secondary small mb-3">@Option.Description</p>
                        }
                        @if (Option.DataType == 2) {
                            <FormTextarea Value="@Option.GlobalValue" ValueChanged="OnTemplateValueChanged" Rows="10" CssClass="font-monospace mb-2" />
                            <div class="d-flex gap-2 mb-2">
                                <FormSaveButton OnClick="SaveGlobal" ButtonClass="btn-sm btn-primary" />
                                <button class="btn btn-sm btn-outline-secondary" @onclick="TogglePreview">
                                    <i class="bi bi-eye"></i> Vorschau
                                </button>
                            </div>
                            @if (ShowPreview && PreviewHtml != null) {
                                <div class="card bg-body-secondary">
                                    <div class="card-body">
                                        @((MarkupString)PreviewHtml)
                                    </div>
                                </div>
                            }
                        } else {
                            <div class="input-group mb-2">
                                <FormInput @bind-Value="Option.GlobalValue" Type="@(Option.DataType == 1 ? "number" : "text")" />
                                <FormSaveButton OnClick="SaveGlobal" />
                            </div>
                        }
                    </div>
                </div>
            </DirtyForm>

            @if (Option.IsOverridable) {
                <div class="card mb-3">
                    <div class="card-body">
                        <h5>Gliederungs-Überschreibungen</h5>

                        @if (Option.Overrides.Count > 0) {
                            <div class="table-responsive">
                            <table class="table table-sm mb-3">
                                <thead>
                                    <tr>
                                        <th>Kürzel</th>
                                        <th>Gliederung</th>
                                        <th>Wert</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ov in Option.Overrides) {
                                        <tr>
                                            <td><span class="badge bg-secondary">@ov.ChapterShortCode</span></td>
                                            <td>@ov.ChapterName</td>
                                            <td>
                                                @if (Option.DataType == 2) {
                                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => LoadOverrideForEditing(ov)">
                                                        <i class="bi bi-pencil"></i> Bearbeiten
                                                    </button>
                                                } else {
                                                    <div class="input-group input-group-sm" style="max-width: 300px;">
                                                        <input type="@(Option.DataType == 1 ? "number" : "text")"
                                                               class="form-control" value="@ov.Value"
                                                               @onchange="(e) => SaveOverride(ov.ChapterId, e.Value?.ToString() ?? string.Empty)" />
                                                        <button class="btn btn-outline-primary" aria-label="Speichern" @onclick="() => SaveOverride(ov.ChapterId, ov.Value)">
                                                            <i class="bi bi-save"></i>
                                                        </button>
                                                    </div>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            </div>
                        } else {
                            <p class="text-secondary">Keine Überschreibungen vorhanden.</p>
                        }

                        @if (EditingOverride != null) {
                            <hr />
                            <h6>Überschreibung bearbeiten: @EditingOverride.ChapterName</h6>
                            <textarea class="form-control font-monospace mb-2" rows="8"
                                      @bind="EditingOverrideValue" @bind:event="oninput"></textarea>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-primary" @onclick="SaveEditingOverride">
                                    <i class="bi bi-save"></i> Speichern
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEditingOverride">
                                    Abbrechen
                                </button>
                            </div>
                        }

                        <hr />
                        <div class="d-flex gap-2 align-items-center">
                            <select class="form-select form-select-sm" style="width: auto;" @bind="NewOverrideChapterId">
                                <option value="">Gliederung hinzufügen...</option>
                                @if (Chapters != null) {
                                    @foreach (var ch in Chapters.Where(c => !string.IsNullOrEmpty(c.ShortCode))) {
                                        @if (!Option.Overrides.Any(o => o.ChapterId == ch.Id)) {
                                            <option value="@ch.Id">@ch.Name (@ch.ShortCode)</option>
                                        }
                                    }
                                }
                            </select>
                            <button class="btn btn-sm btn-outline-success" @onclick="AddOverride">
                                <i class="bi bi-plus"></i> Hinzufügen
                            </button>
                        </div>
                    </div>
                </div>
            } else {
                <div class="card mb-3">
                    <div class="card-body text-secondary">
                        <i class="bi bi-info-circle me-1"></i> Diese Einstellung kann nicht pro Gliederung überschrieben werden.
                    </div>
                </div>
            }
        </div>

        @if (Option.DataType == 2 && Schemas != null && Schemas.Count > 0) {
            <div class="col-lg-4">
                <div class="card position-sticky" style="top: 1rem;">
                    <div class="card-body">
                        <h5>Verfügbare Felder</h5>
                        @foreach (var schema in Schemas) {
                            <h6 class="mt-3 mb-1">
                                <code>@schema.VariablePrefix</code>
                                <span class="text-secondary small">(@schema.ModelName)</span>
                            </h6>
                            <div class="table-responsive">
                            <table class="table table-sm table-borderless mb-0">
                                <tbody>
                                    @foreach (var field in schema.Fields) {
                                        <tr>
                                            <td class="py-0">
                                                <code class="small">@field.Name</code>
                                                <span class="text-secondary small">@field.Type</span>
                                            </td>
                                            <td class="py-0 text-end" style="width: 40px;">
                                                <button class="btn btn-outline-secondary btn-sm py-0 px-1"
                                                        title="In Template einfügen" aria-label="In Template einfügen"
                                                        @onclick="() => InsertField(field.FluidExpression)">
                                                    <i class="bi bi-plus-circle" style="font-size: 0.75rem;"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
