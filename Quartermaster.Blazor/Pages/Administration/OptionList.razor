@page "/Administration/Options"
@using Quartermaster.Api.Options

<div class="mb-3">
    <h3>System - Einstellungen</h3>
</div>

@if (Loading) {
    <div class="d-flex justify-content-center my-4">
        <div class="spinner-border" role="status"></div>
    </div>
} else if (Options != null) {
    <div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Kennung</th>
                <th>Typ</th>
                <th>Überschreibbar</th>
                <th>Überschreibungen</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var opt in Options) {
                <tr>
                    <td><a href="/Administration/Options/@opt.Id">@opt.FriendlyName</a></td>
                    <td><code>@opt.Identifier</code></td>
                    <td><span class="badge border @DataTypeBadge(opt.DataType)">@DataTypeLabel(opt.DataType)</span></td>
                    <td>
                        @if (opt.IsOverridable) {
                            <i class="bi bi-check-circle text-success"></i>
                        }
                    </td>
                    <td>@opt.Overrides.Count</td>
                </tr>
            }
        </tbody>
    </table>
    </div>
}
