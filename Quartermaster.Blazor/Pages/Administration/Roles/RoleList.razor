@page "/Administration/Roles"
@using Quartermaster.Api.Roles

<PageHeader Title="Rollen">
    <Actions>
        <a href="/Administration/Roles/Assignments" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-person-badge"></i> Zuweisungen
        </a>
        <button class="btn btn-sm btn-primary" @onclick="ShowCreateForm">
            <i class="bi bi-plus-circle"></i> Neue Rolle
        </button>
    </Actions>
</PageHeader>

@if (Loading) {
    <LoadingSpinner />
} else if (Roles != null) {
    <div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Scope</th>
                <th>Berechtigungen</th>
                <th>System</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Roles) {
                <tr>
                    <td>
                        <a href="/Administration/Roles/@r.Id">@r.Name</a>
                        @if (!string.IsNullOrEmpty(r.Description)) {
                            <div class="small text-secondary">@r.Description</div>
                        }
                    </td>
                    <td>
                        @if (r.Scope == 0) {
                            <span class="badge border border-info text-info-emphasis">Global</span>
                        } else {
                            <span class="badge border border-primary text-primary-emphasis">Chapter</span>
                        }
                    </td>
                    <td>@r.Permissions.Count</td>
                    <td>
                        @if (r.IsSystem) {
                            <span class="badge bg-secondary">System</span>
                        }
                    </td>
                    <td class="text-end">
                        @if (!r.IsSystem) {
                            <DeleteButton OnClick="() => DeleteRole(r)" Text="" AriaLabel="Rolle löschen" />
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>
}

@if (ShowingCreateForm) {
    <div class="card mt-4">
        <div class="card-body">
            <h5>Neue Rolle erstellen</h5>
            <div class="mb-3">
                <label class="form-label">Name</label>
                <input type="text" class="form-control" @bind="NewName" />
            </div>
            <div class="mb-3">
                <label class="form-label">Beschreibung</label>
                <textarea class="form-control" @bind="NewDescription" rows="2"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Scope</label>
                <select class="form-select" @bind="NewScope" @bind:after="OnScopeChanged">
                    <option value="0">Global</option>
                    <option value="1">Chapter-scoped</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Berechtigungen</label>
                @if (AvailablePermissions != null) {
                    <div class="border rounded p-2" style="max-height: 300px; overflow-y: auto;">
                        @foreach (var perm in FilteredPermissions) {
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="perm_@perm.Identifier"
                                       checked="@NewPermissions.Contains(perm.Identifier)"
                                       @onchange="e => TogglePerm(perm.Identifier, (bool)e.Value!)" />
                                <label class="form-check-label" for="perm_@perm.Identifier">
                                    @perm.DisplayName <small class="text-secondary">(@perm.Identifier)</small>
                                </label>
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary" @onclick="CreateRole" disabled="@Creating">
                    @if (Creating) {
                        <span class="spinner-border spinner-border-sm"></span>
                    }
                    <span> Erstellen</span>
                </button>
                <button class="btn btn-outline-secondary" @onclick="() => ShowingCreateForm = false">Abbrechen</button>
            </div>
        </div>
    </div>
}
