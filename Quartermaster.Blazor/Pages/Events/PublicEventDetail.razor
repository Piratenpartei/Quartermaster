@page "/Events/{Id:guid}"
@using Quartermaster.Api.Events

<PageTitle>Event</PageTitle>

<PageBackLink Href="/Events" />

@if (Loading) {
    <LoadingSpinner />
} else if (NotFound) {
    <div class="alert alert-warning">
        Dieses Event ist nicht öffentlich verfügbar.
    </div>
} else if (Event != null) {
    <h1>@Event.PublicName</h1>
    <div class="text-secondary mb-4">
        @Event.ChapterName
        @if (Event.EventDate.HasValue) {
            <span> &mdash; @Event.EventDate.Value.ToString("dd.MM.yyyy")</span>
        }
    </div>

    @if (!string.IsNullOrEmpty(DescriptionHtml)) {
        <div class="card">
            <div class="card-body">
                @((MarkupString)DescriptionHtml)
            </div>
        </div>
    }
}
