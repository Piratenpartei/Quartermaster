@page "/"
@using Quartermaster.Api.Dashboard
@using System.Globalization

<PageTitle>Home</PageTitle>

<h1 class="mb-4">Quartermaster</h1>

@if (Loading) {
    <LoadingSpinner />
} else if (Dashboard != null) {
    @if (Dashboard.PendingApplications != null) {
        <DashboardCard Icon="bi-person-plus"
                       Title="Offene Mitgliedsanträge"
                       TotalCount="@Dashboard.PendingApplications.TotalCount"
                       AllUrl="/Administration/MembershipApplications"
                       IsEmpty="@(Dashboard.PendingApplications.Items.Count == 0)"
                       EmptyMessage="Keine offenen Anträge.">
            <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Gliederung</th>
                        <th>Eingereicht</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var app in Dashboard.PendingApplications.Items) {
                        <tr>
                            <td><a href="/Administration/MembershipApplications/@app.Id">@app.FirstName @app.LastName</a></td>
                            <td>@app.ChapterName</td>
                            <td>@app.SubmittedAt.ToString("dd.MM.yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </DashboardCard>
    }

    @if (Dashboard.PendingDueSelections != null) {
        <DashboardCard Icon="bi-currency-euro"
                       Title="Offene Beitragseinstufungen"
                       TotalCount="@Dashboard.PendingDueSelections.TotalCount"
                       AllUrl="/Administration/DueSelections"
                       IsEmpty="@(Dashboard.PendingDueSelections.Items.Count == 0)"
                       EmptyMessage="Keine offenen Einstufungen.">
            <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th class="text-end">Gewählter Beitrag</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ds in Dashboard.PendingDueSelections.Items) {
                        <tr>
                            <td><a href="/Administration/DueSelections/@ds.Id">@ds.FirstName @ds.LastName</a></td>
                            <td class="text-end">@ds.SelectedDue.ToString("C2", CultureInfo.GetCultureInfo("de-de"))</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </DashboardCard>
    }

    @if (Dashboard.OpenMotions != null) {
        <DashboardCard Icon="bi-file-text"
                       Title="Offene Anträge"
                       TotalCount="@Dashboard.OpenMotions.TotalCount"
                       AllUrl="/Administration/Motions"
                       IsEmpty="@(Dashboard.OpenMotions.Items.Count == 0)"
                       EmptyMessage="Keine offenen Anträge.">
            <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>Titel</th>
                        <th>Gliederung</th>
                        <th>Erstellt</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Dashboard.OpenMotions.Items) {
                        <tr>
                            <td><a href="/Administration/Motions/@m.Id">@m.Title</a></td>
                            <td>@m.ChapterName</td>
                            <td>@m.CreatedAt.ToString("dd.MM.yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </DashboardCard>
    }

    @if (Dashboard.UpcomingEvents != null && Dashboard.UpcomingEvents.Count > 0) {
        <DashboardCard Icon="bi-calendar-event"
                       Title="Kommende Events"
                       AllUrl="/Administration/Events"
                       IsEmpty="false">
            <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Gliederung</th>
                        <th>Datum</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ev in Dashboard.UpcomingEvents) {
                        <tr>
                            <td><a href="/Administration/Events/@ev.Id">@ev.PublicName</a></td>
                            <td>@ev.ChapterName</td>
                            <td>@(ev.EventDate?.ToString("dd.MM.yyyy") ?? "")</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </DashboardCard>
    }

    @if (!HasAnyWidget) {
        <p class="text-secondary">Willkommen im Quartermaster.</p>
    }
}
