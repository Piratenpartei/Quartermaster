@page "/Settings"
@using Quartermaster.Api.Users

<PageTitle>Einstellungen</PageTitle>

@if (Loading) {
    <div class="d-flex justify-content-center my-4">
        <div class="spinner-border" role="status"></div>
    </div>
} else if (Settings == null) {
    <div class="alert alert-warning">Du bist nicht angemeldet.</div>
} else {
    <h3>Mein Konto</h3>

    <div class="row mb-3">
        <div class="@(Settings.Member != null ? "col-12 col-lg-6 mb-3 mb-lg-0" : "col-12")">
            <div class="card h-100">
                <div class="card-body">
                    <h5>Benutzerdaten</h5>
                    <div class="table-responsive">
                    <table class="table table-borderless mb-0">
                        <tbody>
                            <tr><th style="width:180px">Anzeigename</th><td>@Settings.User.DisplayName</td></tr>
                            <tr><th>Benutzername</th><td>@(string.IsNullOrEmpty(Settings.User.Username) ? "---" : Settings.User.Username)</td></tr>
                            <tr><th>E-Mail</th><td>@(string.IsNullOrEmpty(Settings.User.EMail) ? "---" : Settings.User.EMail)</td></tr>
                            <tr>
                                <th>Anmeldemethode</th>
                                <td>
                                    @if (Settings.User.Username == Settings.User.EMail) {
                                        <span class="badge bg-primary"><i class="bi bi-shield-lock me-1"></i>SSO</span>
                                    } else {
                                        <span class="badge bg-secondary"><i class="bi bi-person-fill me-1"></i>Manuell</span>
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    </div>
                </div>
            </div>
        </div>
        @if (Settings.Member != null) {
            <div class="col-12 col-lg-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h5>Mitgliedschaft</h5>
                        <div class="table-responsive">
                        <table class="table table-borderless mb-0">
                            <tbody>
                                <tr><th style="width:180px">Mitgliedsnummer</th><td>@Settings.Member.MemberNumber</td></tr>
                                <tr><th>Gliederung</th><td>@(string.IsNullOrEmpty(Settings.Member.ChapterName) ? "---" : Settings.Member.ChapterName)</td></tr>
                                <tr><th>Eintrittsdatum</th><td>@(Settings.Member.EntryDate?.ToString("dd.MM.yyyy") ?? "---")</td></tr>
                                <tr><th>Mitgliedsbeitrag</th><td>@Settings.Member.MembershipFee.ToString("0.00") &euro;/Jahr</td></tr>
                                @if (Settings.Member.ReducedFee > 0) {
                                    <tr><th>Ermäßigter Beitrag</th><td>@Settings.Member.ReducedFee.ToString("0.00") &euro;/Jahr</td></tr>
                                }
                                <tr>
                                    <th>Stimmberechtigung</th>
                                    <td>
                                        @if (Settings.Member.HasVotingRights) {
                                            <span class="badge bg-success">Ja</span>
                                        } else if (Settings.Member.OpenFeeTotal.HasValue && Settings.Member.OpenFeeTotal.Value > 0) {
                                            <span class="badge bg-danger">Nein, @Settings.Member.OpenFeeTotal.Value.ToString("0.00") &euro; offen</span>
                                        } else {
                                            <span class="badge bg-secondary">Nein</span>
                                        }
                                    </td>
                                </tr>
                                @if (Settings.Member.IsPending) {
                                    <tr>
                                        <th>Status</th>
                                        <td><span class="badge bg-warning text-dark">Schwebend</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row mb-3">
        <div class="col-12 col-lg-6 mb-3 mb-lg-0">
            <div class="card h-100">
                <div class="card-body">
                    <h5>Globale Berechtigungen</h5>
                    @if (Settings.GlobalPermissions.Count > 0) {
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var perm in Settings.GlobalPermissions) {
                                <span class="badge bg-success" title="@perm.Identifier">@perm.DisplayName</span>
                            }
                        </div>
                    } else {
                        <p class="text-secondary mb-0">Keine globalen Berechtigungen.</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-6">
            <div class="card h-100">
                <div class="card-body">
                    <h5>Gliederungs-Berechtigungen</h5>
                    @if (Settings.ChapterPermissions.Count > 0) {
                        @foreach (var chapter in Settings.ChapterPermissions) {
                            <div class="mb-2">
                                <strong>@chapter.ChapterName</strong>
                                <div class="d-flex flex-wrap gap-1 mt-1">
                                    @foreach (var perm in chapter.Permissions) {
                                        <span class="badge bg-primary" title="@perm.Identifier">@perm.DisplayName</span>
                                    }
                                </div>
                            </div>
                        }
                    } else {
                        <p class="text-secondary mb-0">Keine Gliederungs-Berechtigungen.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (IsDebug) {
        <div class="card mt-3">
            <div class="card-body">
                <h5>Entwicklung</h5>
                <p class="text-secondary small mb-2">Diese Optionen sind nur im Entwicklungsmodus sichtbar.</p>
                <button class="btn btn-sm btn-outline-secondary" @onclick="SeedTestData" disabled="@Seeding">
                    @if (Seeding) {
                        <span class="spinner-border spinner-border-sm"></span>
                    }
                    <i class="bi bi-database-add"></i> Testdaten erstellen
                </button>
            </div>
        </div>
    }
}
